            "https://drive.google.com/drive/u/0/home",
            "https://www.youtube.com/",
            "https://open.spotify.com/intl-tr",
            "https://www.youtube.com/",
            "https://www.youtube.com/",
            
          ],
          tags: ["Mystery", "Psychological"],
          score: 8.3,
          synopsis: "Düş ve gerçeklik arasında sıkışan bir labirentte kayboluş.",
        },
      ];

      // State
      let state = {
        page: 1,
        perPage: 10,
        query: "",
        type: "Hepsi", // Hepsi | Anime | 18+
        lang: "Hepsi", // Hepsi | SUB | DUB
        only18: false,
        selected: null,
        tags: new Set(),
        continue: JSON.parse(localStorage.getItem("aikoshi-continue") || "[]"),
      };

      // Elements
      const grid = document.getElementById("grid");
      const loadMore = document.getElementById("loadMore");
      const search = document.getElementById("search");
      const searchMobile = document.getElementById("searchMobile");
      const openSearch = document.getElementById("openSearch");
      const filterType = document.getElementById("filterType");
      const filterLang = document.getElementById("filterLang");
      const sortSel = document.getElementById("sort");
      const countInfo = document.getElementById("countInfo");
      const details = document.getElementById("details");
      const dImage = document.getElementById("dImage");
      const dTitle = document.getElementById("dTitle");
      const dScore = document.getElementById("dScore");
      const dEpisodes = document.getElementById("dEpisodes");
      const dBadges = document.getElementById("dBadges");
      const dSynopsis = document.getElementById("dSynopsis");
      const dTags = document.getElementById("dTags");
      const dEpisodesList = document.getElementById("dEpisodesList");
      const btnPlay = document.getElementById("btnPlay");
      const closeDetails = document.getElementById("closeDetails");

      const ageGate = document.getElementById("ageGate");
      const toggle18 = document.getElementById("toggle18");
      const toggle18Indicator = document.getElementById("toggle18Indicator");
      const accept18 = document.getElementById("accept18");
      const cancel18 = document.getElementById("cancel18");

      const openFilters = document.getElementById("openFilters");
      const filtersSheet = document.getElementById("filtersSheet");
      const closeFilters = document.getElementById("closeFilters");
      const tagCloud = document.getElementById("tagCloud");
      const resetFilters = document.getElementById("resetFilters");
      const applyFilters = document.getElementById("applyFilters");

      const continueSection = document.getElementById("continueSection");
      const continueList = document.getElementById("continueList");
      const clearContinue = document.getElementById("clearContinue");

      const year = document.getElementById("year");
      year.textContent = new Date().getFullYear();

      // Helpers
      function clamp(n, min, max) { return Math.max(min, Math.min(max, n)); }

      function makeBadge(text, variant = "default") {
        const base = "inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-medium ring-1";
        const map = {
          default: base + " bg-zinc-800/80 text-zinc-200 ring-zinc-700",
          green: base + " bg-emerald-500/15 text-emerald-300 ring-emerald-500/30",
          pink: base + " bg-pink-500/15 text-pink-300 ring-pink-500/30",
          amber: base + " bg-amber-500/15 text-amber-300 ring-amber-500/30",
          red: base + " bg-red-500/15 text-red-300 ring-red-500/30",
        };
        const span = document.createElement("span");
        span.className = map[variant] || map.default;
        span.textContent = text;
        return span;
      }

      function createCard(item) {
        const btn = document.createElement("button");
        btn.className = "group flex w-full flex-col gap-3 text-left focus:outline-none card-hover";
        btn.innerHTML = `
          <div class="relative">
            <div class="relative aspect-[2/3] w-full overflow-hidden rounded-xl bg-gradient-to-br from-zinc-800 to-zinc-900 ring-1 ring-zinc-800">
              <img alt="${item.title}" class="absolute inset-0 h-full w-full object-cover opacity-90 transition-transform group-hover:scale-105" src="${item.image}" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/10"></div>
              ${item.is18 ? '<div class="absolute left-2 top-2 z-10">' + makeBadge('18+','red').outerHTML + '</div>' : ''}
              <div class="absolute bottom-2 right-2 z-10">${makeBadge(''+item.score,'amber').outerHTML}</div>
            </div>
            <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-white/10 group-hover:ring-white/25"></div>
            <div class="absolute left-2 bottom-2 flex items-center gap-1.5">
              ${item.sub ? makeBadge('SUB','green').outerHTML : ''}
              ${item.dub ? makeBadge('DUB','pink').outerHTML : ''}
              ${makeBadge('Ep '+item.episodes).outerHTML}
            </div>
          </div>
          <div class="px-0.5">
            <h3 class="line-clamp-1 text-sm font-semibold text-zinc-100">${item.title}</h3>
            <p class="line-clamp-2 text-xs text-zinc-400">${item.synopsis}</p>
            <div class="mt-1.5 flex flex-wrap gap-1.5">${item.tags.slice(0,3).map(t=>makeBadge(t).outerHTML).join("")}</div>
          </div>`;
        btn.addEventListener("click", () => openDetails(item));
        return btn;
      }

      function openDetails(item) {
        state.selected = item;
        dImage.src = item.image;
        dTitle.textContent = item.title;
        dScore.textContent = String(item.score);
        dEpisodes.textContent = item.episodes + " Bölüm";
        dBadges.innerHTML = (item.is18 ? makeBadge('18+','red').outerHTML : '') + (item.sub ? makeBadge('SUB','green').outerHTML : '') + (item.dub ? makeBadge('DUB','pink').outerHTML : '');
        dSynopsis.textContent = item.synopsis;
        dTags.innerHTML = item.tags.map(t=>makeBadge(t).outerHTML).join("");
        /* ↓↓↓ Bölüm listesi: links varsa anchor (<a>) olarak çiz, yoksa eski butonları kullan ↓↓↓ */
        if (Array.isArray(item.links) && item.links.length) {
          dEpisodesList.innerHTML = item.links.map((href, i) => `
            <a href="${href}" target="_blank" rel="noopener"
               class="flex w-full items-center justify-between rounded-lg bg-zinc-900/60 px-3 py-2 text-left text-sm text-emerald-300 hover:bg-zinc-800 hover:underline">
              <span>Ep ${i+1}</span>
              <span class="text-xs text-zinc-400">24 dk</span>
            </a>
          `).join("");
        } else {
          dEpisodesList.innerHTML = Array.from({length:item.episodes}).map((_,i)=>`
            <button class="flex w-full items-center justify-between rounded-lg bg-zinc-900/60 px-3 py-2 text-left text-sm text-zinc-200 transition-colors hover:bg-zinc-800">
              <span>Ep ${i+1}</span><span class="text-xs text-zinc-400">24 dk</span>
            </button>`).join("");
        }
        details.classList.remove("hidden");
      }

      closeDetails.addEventListener("click", () => details.classList.add("hidden"));
      details.addEventListener("click", (e) => { if (e.target === details) details.classList.add("hidden"); });

      btnPlay.addEventListener("click", () => {
        if (!state.selected) return;
        // Eğer linkler tanımlıysa ilkine git
        if (Array.isArray(state.selected.links) && state.selected.links.length) {
          window.open(state.selected.links[0], "_blank", "noopener");
          return;
        }
        // örnek olarak ep 1'e başlandı kabul edelim
        const entry = { id: state.selected.id, title: state.selected.title, image: state.selected.image, ep: 1, progress: 12 };
        const arr = state.continue.filter(x=>x.id!==entry.id);
        arr.unshift(entry);
        state.continue = arr.slice(0, 12);
        localStorage.setItem("aikoshi-continue", JSON.stringify(state.continue));
        renderContinue();
      });

      function renderContinue() {
        if (!state.continue.length) {
          continueSection.classList.add("hidden");
          return;
        }
        continueSection.classList.remove("hidden");
        continueList.innerHTML = state.continue.map(c=>`
          <div class="relative h-28 w-48 shrink-0 overflow-hidden rounded-xl ring-1 ring-white/10 card-hover">
            <img src="${c.image}" class="absolute inset-0 h-full w-full object-cover" alt="${c.title}" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/70"></div>
            <div class="absolute inset-x-0 bottom-0 h-1 bg-zinc-700">
              <div class="h-full bg-gradient-to-r from-emerald-500 to-cyan-500" style="width:${clamp(c.progress,0,100)}%"></div>
            </div>
            <div class="absolute left-2 bottom-4 right-2 text-xs font-medium">${c.title} – Ep ${c.ep}</div>
          </div>`).join("");
      }

      clearContinue.addEventListener("click", ()=>{
        state.continue = [];
        localStorage.removeItem("aikoshi-continue");
        renderContinue();
      });

      function applyQuery(val) {
        state.query = val.toLowerCase();
        state.page = 1; render();
      }

      search?.addEventListener("input", (e)=> applyQuery(e.target.value));
      searchMobile?.addEventListener("input", (e)=> applyQuery(e.target.value));
      openSearch?.addEventListener("click", ()=> {
        const el = document.getElementById("mobileSearchBar");
        el.classList.toggle("hidden");
        document.getElementById("searchMobile").focus();
      });

      filterType.addEventListener("change", ()=>{ state.type = filterType.value; state.page = 1; render(); });
      filterLang.addEventListener("change", ()=>{ state.lang = filterLang.value; state.page = 1; render(); });
      sortSel.addEventListener("change", ()=>{ state.sort = sortSel.value; state.page = 1; render(); });

      // 18+ toggle with Age Gate
      toggle18.addEventListener("click", ()=> {
        if (!state.only18) {
          ageGate.classList.remove("hidden");
        } else {
          state.only18 = false; // kapat
          toggle18Indicator.firstElementChild.style.transform = "translateX(0px)";
          toggle18Indicator.classList.remove("bg-emerald-500/40");
          render();
        }
      });
      accept18.addEventListener("click", ()=>{
        state.only18 = true;
        ageGate.classList.add("hidden");
        toggle18Indicator.firstElementChild.style.transform = "translateX(1.0rem)"; // 16px
        toggle18Indicator.classList.add("bg-emerald-500/40");
        render();
      });
      cancel18.addEventListener("click", ()=>{
        ageGate.classList.add("hidden");
      });

      // Filters sheet
      openFilters.addEventListener("click", ()=> filtersSheet.classList.remove("hidden"));
      closeFilters.addEventListener("click", ()=> filtersSheet.classList.add("hidden"));
      filtersSheet.addEventListener("click", (e)=>{ if (e.target===filtersSheet) filtersSheet.classList.add("hidden"); });

      // tag cloud
      const ALL_TAGS = Array.from(new Set(DATA.flatMap(d=>d.tags))).sort();
      tagCloud.innerHTML = ALL_TAGS.map(t=>`<button data-tag="${t}" class="tagBtn rounded-full border border-zinc-700 bg-zinc-900 px-3 py-1 text-xs transition-colors hover:bg-zinc-800">${t}</button>`).join("");
      tagCloud.addEventListener("click", (e)=>{
        const btn = e.target.closest(".tagBtn"); if (!btn) return;
        const t = btn.dataset.tag;
        if (state.tags.has(t)) { state.tags.delete(t); btn.classList.remove("ring-emerald-400","border-emerald-400"); }
        else { state.tags.add(t); btn.classList.add("ring-emerald-400","border-emerald-400"); }
      });

      // lang/type quick buttons inside sheet
      document.querySelectorAll(".langBtn").forEach(b=> b.addEventListener("click", ()=>{ state.lang = b.dataset.lang; }));
      document.querySelectorAll(".typeBtn").forEach(b=> b.addEventListener("click", ()=>{ state.type = b.dataset.type; }));

      resetFilters.addEventListener("click", ()=>{
        state.tags.clear();
        state.lang = "Hepsi"; state.type = "Hepsi";
        tagCloud.querySelectorAll(".tagBtn").forEach(btn=> btn.classList.remove("ring-emerald-400","border-emerald-400"));
      });
      applyFilters.addEventListener("click", ()=>{ filtersSheet.classList.add("hidden"); render(); });

      // Theme
      const themeBtn = document.getElementById("themeBtn");
      const themeIcon = document.getElementById("themeIcon");
      function setTheme(mode) {
        const root = document.documentElement;
        if (mode === "light") { root.classList.remove("dark"); themeIcon.textContent = "🌞"; }
        else { root.classList.add("dark"); themeIcon.textContent = "🌙"; }
        localStorage.setItem("aikoshi-theme", mode);
      }
      themeBtn.addEventListener("click", ()=>{
        const mode = document.documentElement.classList.contains("dark") ? "light" : "dark";
        setTheme(mode);
      });
      (function initTheme(){ const saved=localStorage.getItem("aikoshi-theme"); if(saved) setTheme(saved); })();

      // Render
      function getFiltered() {
        let items = DATA.slice();
        if (state.only18) items = items.filter(i=>i.is18);
        if (state.type !== "Hepsi") items = items.filter(i=> state.type === "18+" ? i.is18 : !i.is18);
        if (state.lang !== "Hepsi") items = items.filter(i=> state.lang==="SUB" ? i.sub : i.dub);
        if (state.tags.size) items = items.filter(i=> i.tags.some(t=> state.tags.has(t)) );
        if (state.query) items = items.filter(i=> i.title.toLowerCase().includes(state.query) || i.tags.some(t=> t.toLowerCase().includes(state.query)));
        if (state.sort === "a2z") items.sort((a,b)=> a.title.localeCompare(b.title));
        if (state.sort === "z2a") items.sort((a,b)=> b.title.localeCompare(a.title));
        // pop default -> score desc
        if (state.sort === "pop") items.sort((a,b)=> b.score - a.score);
        return items;
      }

      function render() {
        const all = getFiltered();
        countInfo.textContent = `${all.length} başlık`;
        const end = state.page * state.perPage;
        const view = all.slice(0, end);
        grid.innerHTML = "";
        view.forEach(item=> grid.appendChild(createCard(item)));
        loadMore.classList.toggle("hidden", end >= all.length);
      }

      loadMore.addEventListener("click", ()=>{ state.page++; render(); });

      // Init
      render();
      renderContinue();
    </script>
  </body>
</html>
