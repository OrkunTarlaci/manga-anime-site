        const skeletonHTML = Array(12).fill(0).map(() => `
          <div class="skeleton-card">
            <div class="skeleton skeleton-image"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text short"></div>
          </div>
        `).join('');
        document.getElementById('skeletonGrid').innerHTML = skeletonHTML;
      }

      // ============================================
      // NOTIFICATION SİSTEMİ
      // ============================================
      function showNotification(text, type = 'success') {
        const notif = document.getElementById('notification');
        const icon = document.getElementById('notifIcon');
        const txt = document.getElementById('notifText');
        
        icon.textContent = type === 'success' ? '✓' : type === 'error' ? '✕' : 'ℹ️';
        txt.textContent = text;
        
        notif.classList.add('show');
        setTimeout(() => {
          notif.classList.remove('show');
        }, 3000);
      }

      // ============================================
      // SON OKUNAN
      // ============================================
      function saveLastRead(mangaId, episodeIndex) {
        state.lastRead[mangaId] = {
          episode: episodeIndex,
          timestamp: Date.now()
        };
        localStorage.setItem('lastRead', JSON.stringify(state.lastRead));
      }

      function loadLastRead() {
        const saved = localStorage.getItem('lastRead');
        if (saved) {
          state.lastRead = JSON.parse(saved);
        }
      }

      function continueReading() {
        if (!state.selected) return;
        const last = state.lastRead[state.selected.id];
        if (last) {
          window.open(state.selected.episodes[last.episode], '_blank');
        }
      }
      window.continueReading = continueReading;

      function updateContinueReading() {
        const last = state.selected ? state.lastRead[state.selected.id] : null;
        document.getElementById('continueReading').classList.toggle('hidden', !last);
      }

      // ============================================
      // BÖLÜM SIRALAMA
      // ============================================
      function toggleEpisodeSort() {
        state.episodeSortDesc = !state.episodeSortDesc;
        const btn = document.getElementById('episodeSort');
        btn.innerHTML = state.episodeSortDesc ? 
          '<span>↓</span><span>En Yeni</span>' : 
          '<span>↑</span><span>En Eski</span>';
        
        if (state.selected) {
          renderEpisodesList(state.selected);
        }
      }
      window.toggleEpisodeSort = toggleEpisodeSort;

      function renderEpisodesList(item) {
        let episodes = [...item.episodes];
        if (!state.episodeSortDesc) {
          episodes = episodes.reverse();
        }
        
        let episodesHtml = '';
        episodes.forEach((link, i) => {
          const actualIndex = state.episodeSortDesc ? i : item.episodes.length - 1 - i;
          const isLastRead = state.lastRead[item.id]?.episode === actualIndex;
          episodesHtml += `
            <a href="${link}" target="_blank" onclick="saveLastRead(${item.id}, ${actualIndex})" 
               class="flex w-full items-center justify-between rounded-lg ${isLastRead ? 'bg-red-900/30 border border-red-500/30' : 'bg-zinc-900/60'} px-4 py-3 text-red-300 hover:bg-zinc-800 transition-colors">
              <span class="flex items-center gap-2">
                ${isLastRead ? '' : ''}Bölüm ${actualIndex + 1}
              </span>
              <span class="text-zinc-400">↗</span>
            </a>
          `;
        });
        document.getElementById("dEpisodesList").innerHTML = episodesHtml;
      }

      // ============================================
      // BİZE ULAŞIN MODAL
      // ============================================
      function openContactModal() {
        document.getElementById("contactModal").classList.add("active");
        document.body.style.overflow = "hidden";
      }
      window.openContactModal = openContactModal;

      function closeContactModal() {
        document.getElementById("contactModal").classList.remove("active");
        document.body.style.overflow = "";
        setTimeout(() => {
          document.getElementById("contactForm").reset();
          document.getElementById("contactFormContainer").style.display = "block";
          document.getElementById("successMessage").classList.remove("active");
          document.getElementById("submitBtn").disabled = false;
          document.getElementById("submitBtn").classList.remove("sending");
          document.getElementById("submitBtn").innerHTML = "<span>Gönder</span>";
        }, 300);
      }
      window.closeContactModal = closeContactModal;

      let lastSubmitTime = 0;
      
      document.getElementById("contactForm").addEventListener("submit", async function(e) {
        e.preventDefault();
        
        if (Date.now() - lastSubmitTime < 30000) {
          showNotification('Lütfen 30 saniye bekleyin', 'error');
          return;
        }
        
        const submitBtn = document.getElementById("submitBtn");
        submitBtn.disabled = true;
        submitBtn.classList.add("sending");
        submitBtn.innerHTML = "<span class='loading-spinner'></span><span>Gönderiliyor...</span>";

        const formData = new FormData(this);
        
        try {
          await new Promise(resolve => setTimeout(resolve, 1500));
          
          lastSubmitTime = Date.now();
          document.getElementById("contactFormContainer").style.display = "none";
          document.getElementById("successMessage").classList.add("active");
          showNotification('Mesajınız gönderildi!', 'success');
          
          setTimeout(() => {
            closeContactModal();
          }, 3000);
        } catch (error) {
          showNotification('Bir hata oluştu', 'error');
          submitBtn.disabled = false;
          submitBtn.classList.remove("sending");
          submitBtn.innerHTML = "<span>Gönder</span>";
        }
      });

      document.getElementById("contactModal").addEventListener("click", function(e) {
        if (e.target === this) closeContactModal();
      });

      // ============================================
      // SCROLL TO TOP
      // ============================================
      function scrollToTop() {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
      window.scrollToTop = scrollToTop;

      window.addEventListener('scroll', () => {
        const btn = document.getElementById('scrollTop');
        if (window.scrollY > 500) {
          btn.classList.add('visible');
        } else {
          btn.classList.remove('visible');
        }
      });

      // ============================================
      // TARİH FONKSİYONLARI
      // ============================================
      function parseDate(dateStr) {
        const parts = dateStr.split('.');
        return new Date(parseInt(parts[2]), parseInt(parts[1]) - 1, parseInt(parts[0]));
      }

      function isNewManga(addedDate) {
        const added = parseDate(addedDate);
        const now = new Date();
        const diffTime = Math.abs(now - added);
        const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
        return diffDays <= 2;
      }

      // ============================================
      // KATEGORİ FONKSİYONLARI
      // ============================================
      function getCurrentCategories() {
        return state.plus18Mode ? PLUS18_CATEGORIES : NORMAL_CATEGORIES;
      }

      function getCategoryCount(category) {
        if (!DATA.length) return 0;
        return DATA.filter(item => 
          item.tags.some(tag => tag.toLowerCase() === category.toLowerCase()) &&
          (state.plus18Mode ? item.plus18 === true : item.plus18 === false)
        ).length;
      }

      function renderCategoryGrid() {
        const container = document.getElementById('categoryGrid');
        const categories = getCurrentCategories();
        
        let html = categories.map(cat => {
          const isActive = state.tags.has(cat);
          const count = getCategoryCount(cat);
          return `
            <div onclick="selectCategory('${cat}')" 
                 class="category-card ${isActive ? 'active' : ''}">
              <div class="category-card-content">
                <span class="category-name">${cat}</span>
                <span class="category-count">${count} manga</span>
              </div>
            </div>
          `;
        }).join('');
        
        container.innerHTML = html;
      }

      function selectCategory(category) {
        // Tek tıkla filtre uygula
        state.tags.clear();
        state.tags.add(category);
        state.currentPage = 1;
        
        // Sheet'i kapat
        document.getElementById("categoriesSheet").classList.remove('active');
        document.body.style.overflow = '';
        
        // Güncelle ve göster
        updateActiveFilters();
        render();
        showNotification(`${category} kategorisi filtrelendi`, 'success');
      }
      window.selectCategory = selectCategory;

      function updateActiveFilters() {
        const container = document.getElementById('activeFilters');
        const tagsContainer = document.getElementById('filterTags');
        
        if (state.tags.size === 0) {
          container.classList.add('hidden');
          return;
        }
        
        container.classList.remove('hidden');
        let html = '';
        
        state.tags.forEach(tag => {
          html += `<span class="active-filter">${tag} <button onclick="removeFilter('${tag}')">✕</button></span>`;
        });
        
        tagsContainer.innerHTML = html;
      }

      function removeFilter(tag) {
        state.tags.delete(tag);
        state.currentPage = 1;
        updateActiveFilters();
        render();
      }
      window.removeFilter = removeFilter;

      function updateCategoryModeBadge() {
        const badge = document.getElementById('categoryModeBadge');
        if (state.plus18Mode) {
          badge.className = 'mode-badge plus18';
          badge.textContent = '+18 Mod';
        } else {
          badge.className = 'mode-badge normal';
          badge.textContent = 'Normal Mod';
        }
      }

      function openCategoriesSheet() {
        document.getElementById("categoriesSheet").classList.add('active');
        document.body.style.overflow = 'hidden';
        updateCategoryModeBadge();
        renderCategoryGrid();
      }

      function closeCategoriesSheet() {
        document.getElementById("categoriesSheet").classList.remove('active');
        document.body.style.overflow = '';
      }

      // ============================================
      // MOBİL +18 TOGGLE
      // ============================================
      function toggleMobilePlus18() {
        state.plus18Mode = !state.plus18Mode;
        
        // Buton görünümünü güncelle
        const btn = document.getElementById('mobilePlus18Btn');
        if (state.plus18Mode) {
          btn.classList.add('active');
        } else {
          btn.classList.remove('active');
        }
        
        // Banner'ı göster/gizle
        document.getElementById("plus18Banner").classList.toggle("hidden", !state.plus18Mode);
        
        // Filtreleri sıfırla
        state.tags.clear();
        state.currentPage = 1;
        updateActiveFilters();
        render();
        renderFeaturedCards();
      }

      // ============================================
      // SAYFALAMA
      // ============================================
      function renderPagination(totalItems) {
        const totalPages = Math.ceil(totalItems / state.itemsPerPage);
        const pagination = document.getElementById('pagination');

        if (totalPages <= 1) {
          pagination.innerHTML = '';
          return;
        }

        let html = '';
        html += `<button onclick="goToPage(${state.currentPage - 1})" class="page-btn nav" ${state.currentPage === 1 ? 'disabled' : ''}>← Önceki</button>`;

        for (let i = 1; i <= totalPages; i++) {
          if (i === 1 || i === totalPages || (i >= state.currentPage - 2 && i <= state.currentPage + 2)) {
            html += `<button onclick="goToPage(${i})" class="page-btn ${i === state.currentPage ? 'active' : ''}">${i}</button>`;
          } else if (i === state.currentPage - 3 || i === state.currentPage + 3) {
            html += `<span class="text-zinc-500 px-2">...</span>`;
          }
        }

        html += `<button onclick="goToPage(${state.currentPage + 1})" class="page-btn nav" ${state.currentPage === totalPages ? 'disabled' : ''}>Sonraki →</button>`;
        pagination.innerHTML = html;
      }

      function goToPage(page) {
        const filtered = getFiltered();
        const totalPages = Math.ceil(filtered.length / state.itemsPerPage);
        if (page < 1 || page > totalPages) return;
        state.currentPage = page;
        render();
        document.getElementById("list").scrollIntoView({ behavior: 'smooth' });
      }
      window.goToPage = goToPage;

      // ============================================
      // FUZZY SEARCH
      // ============================================
      function fuzzyMatch(str, query) {
        str = str.toLowerCase();
        query = query.toLowerCase();
        
        if (str.includes(query)) return 2;
        
        let matches = 0;
        let queryIdx = 0;
        for (let i = 0; i < str.length && queryIdx < query.length; i++) {
          if (str[i] === query[queryIdx]) {
            matches++;
            queryIdx++;
          }
        }
        return matches >= query.length * 0.7 ? 1 : 0;
      }

      function highlightText(text, query) {
        if (!query) return text;
        const regex = new RegExp(`(${query.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`, 'gi');
        return text.replace(regex, '<span class="highlight">$1</span>');
      }

      // ============================================
      // RENDER FONKSİYONLARI
      // ============================================
      function makeBadge(text, variant = "default") {
        const base = "inline-flex items-center gap-1 rounded-full px-2.5 py-1 text-xs font-medium ring-1 whitespace-nowrap";
        const map = {
          default: base + " bg-zinc-800/80 text-zinc-200 ring-zinc-700",
          pink: base + " bg-pink-500/15 text-pink-300 ring-pink-500/30",
          red: base + " bg-red-500/15 text-red-300 ring-red-500/30",
          green: base + " bg-green-500/15 text-green-300 ring-green-500/30",
        };
        const span = document.createElement("span");
        span.className = map[variant] || map.default;
        span.innerHTML = text;
        return span;
      }

      function createCard(item) {
        const btn = document.createElement("button");
        btn.className = "group flex w-full flex-col gap-3 text-left focus:outline-none card-hover animate-fade-in";
        btn.onclick = () => openDetails(item);

        const isNew = isNewManga(item.addedDate);
        const newBadge = isNew ? '<div class="badge-new">YENİ</div>' : '';
        const plus18Badge = item.plus18 ? '<div class="badge-plus18">+18</div>' : '';

        const titleHtml = state.query ? highlightText(item.title, state.query) : item.title;
        const synopsisHtml = state.query ? highlightText(item.synopsis, state.query) : item.synopsis;

        btn.innerHTML = `
          <div class="relative">
            <div class="relative aspect-[2/3] w-full overflow-hidden rounded-xl bg-gradient-to-br from-zinc-800 to-zinc-900 ring-1 ring-zinc-800 shadow-xl">
              <img alt="${item.title}" class="absolute inset-0 h-full w-full object-cover opacity-90 transition-transform duration-300 group-hover:scale-105" src="${item.image}" loading="lazy" decoding="async" />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80"></div>
              ${newBadge}
              ${plus18Badge}
            </div>
            <div class="pointer-events-none absolute inset-0 rounded-xl ring-1 ring-inset ring-white/10 group-hover:ring-red-400/50"></div>

            <div class="absolute left-3 bottom-3 z-10">
              ${makeBadge(item.episodes.length + ' Bölüm').outerHTML}
            </div>
          </div>
          <div class="px-0.5">
            <h3 class="line-clamp-1 text-base font-semibold text-zinc-100">${titleHtml}</h3>
            <p class="line-clamp-2 text-sm text-zinc-400">${synopsisHtml}</p>
            <div class="mt-2 flex flex-wrap gap-1.5">${item.tags.slice(0,3).map(t=>makeBadge(t,'default').outerHTML).join("")}</div>
          </div>`;
        return btn;
      }

      function openDetails(item) {
        state.selected = item;
        document.getElementById("dImage").src = item.image;
        document.getElementById("dTitle").textContent = item.title;
        document.getElementById("dEpisodes").textContent = item.episodes.length + " Bölüm";
        document.getElementById("dSynopsis").textContent = item.synopsis;
        document.getElementById("dTags").innerHTML = item.tags.map(t=>makeBadge(t,'default').outerHTML).join("");
        document.getElementById("dAddedDate").textContent = item.addedDate;

        const isNew = isNewManga(item.addedDate);
        document.getElementById("dNewBadge").classList.toggle("hidden", !isNew);
        document.getElementById("dNewTag").classList.toggle("hidden", !isNew);
        document.getElementById("dPlus18Badge").classList.toggle("hidden", !item.plus18);
        document.getElementById("dPlus18Tag").classList.toggle("hidden", !item.plus18);

        renderEpisodesList(item);
        updateContinueReading();

        document.getElementById("details").classList.add("active");
        document.body.style.overflow = "hidden";
      }

      function getFiltered() {
        let items = DATA.slice();

        if (state.plus18Mode) {
          items = items.filter(i => i.plus18 === true);
        } else {
          items = items.filter(i => i.plus18 === false);
        }

        if (state.tags.size) {
          items = items.filter(i => i.tags.some(t => state.tags.has(t)));
        }

        if (state.query) {
          const q = state.query.toLowerCase();
          items = items.filter(i => {
            const titleMatch = fuzzyMatch(i.title, q);
            const synopsisMatch = fuzzyMatch(i.synopsis, q);
            const tagMatch = i.tags.some(t => fuzzyMatch(t, q));
            return titleMatch || synopsisMatch || tagMatch;
          });
        }

        return items;
      }

      function sortItems(items) {
        if (state.sort === "popularity") {
          items.sort((a, b) => b.popularity - a.popularity);
        } else if (state.sort === "newest") {
          items.sort((a, b) => parseDate(b.addedDate) - parseDate(a.addedDate));
        } else if (state.sort === "a2z") {
          items.sort((a, b) => a.title.localeCompare(b.title));
        } else if (state.sort === "z2a") {
          items.sort((a, b) => b.title.localeCompare(a.title));
        }
        return items;
      }

      function render() {
        let all = getFiltered();
        all = sortItems(all);

        document.getElementById("countInfo").textContent = `${all.length} manga`;

        const start = (state.currentPage - 1) * state.itemsPerPage;
        const end = start + state.itemsPerPage;
        const view = all.slice(start, end);

        const grid = document.getElementById('grid');
        grid.innerHTML = "";
        if (view.length === 0) {
          grid.innerHTML = `<div class="col-span-full text-center py-12"><p class="text-zinc-400">Sonuç bulunamadı.</p></div>`;
        } else {
          view.forEach(item => grid.appendChild(createCard(item)));
        }

        renderPagination(all.length);
      }

      function renderFeaturedCards() {
        const filtered = getFiltered();
        const sorted = [...filtered].sort((a, b) => b.popularity - a.popularity);
        const featured = sorted.slice(0, 2);

        document.getElementById("featuredCards").innerHTML = featured.map((item, index) => {
          const isNew = isNewManga(item.addedDate);
          return `
          <button onclick='openDetails(DATA.find(d => d.id === ${item.id}))' class="relative aspect-[3/4] overflow-hidden rounded-3xl ring-2 ${index === 0 ? 'ring-red-500/30' : 'ring-pink-500/30'} shadow-2xl card-hover animate-fade-in" style="animation-delay: ${index * 0.1}s">
            <img alt="${item.title}" class="absolute inset-0 h-full w-full object-cover hover:scale-105 transition-transform duration-500" src="${item.image}" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-black/80"></div>
            ${isNew ? '<div class="badge-new">YENİ</div>' : ''}
            ${item.plus18 ? '<div class="badge-plus18">+18</div>' : ''}
            <div class="absolute bottom-4 left-4 right-4">
              <span class="text-lg font-bold">${item.title}</span>
              <div class="flex items-center gap-2 mt-1">
                <span class="rounded bg-zinc-800/80 px-2 py-1 text-xs">${item.episodes.length} Bölüm</span>
              </div>
            </div>
          </button>
        `}).join('');
      }

      // ============================================
      // SEKME DEĞİŞTİRME
      // ============================================
      function showSection(section) {
        document.querySelectorAll('.bottom-nav-item').forEach(el => el.classList.remove('active'));
        event.target.closest('.bottom-nav-item').classList.add('active');
        
        if (section === 'home') {
          state.currentPage = 1;
          updateActiveFilters();
          render();
        }
      }
      window.showSection = showSection;

      // ============================================
      // EVENT LISTENERS
      // ============================================
      document.getElementById("closeDetails").onclick = () => {
        document.getElementById("details").classList.remove("active");
        document.body.style.overflow = "";
      };

      document.getElementById("details").onclick = (e) => {
        if (e.target === document.getElementById("details")) {
          document.getElementById("details").classList.remove("active");
          document.body.style.overflow = "";
        }
      };

      document.querySelector('.details-modal-content').addEventListener('touchstart', (e) => {
        touchStartY = e.touches[0].clientY;
      });

      document.querySelector('.details-modal-content').addEventListener('touchend', (e) => {
        const touchEndY = e.changedTouches[0].clientY;
        if (touchEndY - touchStartY > 100) {
          document.getElementById("details").classList.remove("active");
          document.body.style.overflow = "";
        }
      });

      document.getElementById("toggleCategories").onclick = openCategoriesSheet;
      document.getElementById("closeCategoriesSheet").onclick = closeCategoriesSheet;

      // Desktop +18 toggle
      document.getElementById("plus18Toggle").onchange = (e) => {
        state.plus18Mode = e.target.checked;
        document.getElementById("plus18Banner").classList.toggle("hidden", !state.plus18Mode);
        state.tags.clear();
        state.currentPage = 1;
        updateActiveFilters();
        render();
        renderFeaturedCards();
      };

      // Mobile +18 toggle
      document.getElementById("mobilePlus18Btn").onclick = toggleMobilePlus18;

      document.getElementById("closePlus18Banner").onclick = () => {
        document.getElementById("plus18Banner").classList.add("hidden");
      };

      function handleSearch(e) {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
          state.query = e.target.value;
          state.currentPage = 1;
          render();
        }, 300);
      }

      document.getElementById("search").oninput = handleSearch;
      document.getElementById("searchMobile").oninput = handleSearch;
      
      document.getElementById("openSearch").onclick = () => {
        const mobileSearchBar = document.getElementById("mobileSearchBar");
        mobileSearchBar.classList.remove("hidden");
        document.getElementById("searchMobile").focus();
      };
      
      document.getElementById("closeMobileSearch").onclick = () => {
        document.getElementById("mobileSearchBar").classList.add("hidden");
      };
      
      document.getElementById("sort").onchange = (e) => {
        state.sort = e.target.value;
        render();
      };

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          document.getElementById("details").classList.remove("active");
          document.getElementById("categoriesSheet").classList.remove('active');
          document.getElementById("contactModal").classList.remove('active');
          document.body.style.overflow = '';
        }
        if (e.key === '/' && document.activeElement.tagName !== 'INPUT') {
          e.preventDefault();
          document.getElementById('search').focus();
        }
      });

      // Sheet dışına tıklama
      document.getElementById("categoriesSheet").addEventListener('click', (e) => {
        if (e.target === document.getElementById("categoriesSheet")) {
          closeCategoriesSheet();
        }
      });

      // ============================================
      // INIT
      // ============================================
      document.getElementById("year").textContent = new Date().getFullYear();
      
      renderSkeleton();
      loadLastRead();
      loadData();

      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('sw.js').catch(console.error);
      }
    </script>
  </body>
</html>
