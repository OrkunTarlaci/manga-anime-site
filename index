      const NORMAL_CATEGORIES = ["Romantik", "Aşk", "Drama", "Komedi", "Macera", "Aksiyon", "Gizem", "Fantastik", "Bilim Kurgu", "Spor", "Korku", "Psikolojik", "Okul", "Doğaüstü", "Tarihi", "Askeri", "Polisiye", "Gerilim", "Seinen", "Shounen", "Shoujo", "Josei", "Ecchi", "Harem", "Isekai", "Mecha", "Müzik", "Slice of Life"];
      const PLUS18_CATEGORIES = ["Anne", "Baba", "Abla", "Abi", "Ensest", "Adult 3D Roman", "Adult Çizgi Roman", "Ahegao", "Aldatma", "Anal", 
      "Anne-Oğul Ensest", "Aşağılama", "Ayak fetişi", "Ayak Yalama", "Baba-Kız Ensest", "Baldız", "Baştan çıkarma", "Bdsm", "Bikini", "Biseksüel","Anne", "Baba", "Abla", "Abi", "Ensest", "Adult 3D Roman", "Adult Çizgi Roman", "Ahegao", "Aldatma", "Anal", 
      "Anne-Oğul Ensest", "Aşağılama", "Ayak fetişi", "Ayak Yalama", "Baba-Kız Ensest", "Baldız", "Baştan çıkarma", "Bdsm", "Bikini", "Biseksüel","Anne", "Baba", "Abla", "Abi", "Ensest", "Adult 3D Roman", "Adult Çizgi Roman", "Ahegao", "Aldatma", "Anal", 
      "Anne-Oğul Ensest", "Aşağılama", "Ayak fetişi", "Ayak Yalama", "Baba-Kız Ensest", "Baldız", "Baştan çıkarma", "Bdsm", "Bikini", "Biseksüel","Anne", "Baba", "Abla", "Abi", "Ensest", "Adult 3D Roman", "Adult Çizgi Roman", "Ahegao", "Aldatma", "Anal", 
      "Anne-Oğul Ensest", "Aşağılama", "Ayak fetişi", "Ayak Yalama", "Baba-Kız Ensest", "Baldız", "Baştan çıkarma", "Bdsm", "Bikini", "Biseksüel","Gore", "Disturbing"];
      
      // ============================================
      // STATE
      // ============================================
      let DATA = [];
      let state = {
        currentPage: 1,
        itemsPerPage: 12,
        query: "",
        sort: "popularity",
        selected: null,
        tags: new Set(),
        plus18Mode: false,
        episodeSortDesc: true,
        lastRead: {}
