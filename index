      let searchTimeout = null;
      let touchStartY = 0;

      // ============================================
      // CACHE SİSTEMİ
      // ============================================
      function getCache() {
        const cached = localStorage.getItem('mangaCache');
        if (cached) {
          const { data, timestamp } = JSON.parse(cached);
          if (Date.now() - timestamp < 3600000) {
            return data;
          }
        }
        return null;
      }

      function setCache(data) {
        localStorage.setItem('mangaCache', JSON.stringify({
          data,
          timestamp: Date.now()
        }));
      }

      // ============================================
      // FETCH SİSTEMİ
      // ============================================
      async function loadData() {
        const cached = getCache();
        if (cached) {
          DATA = cached;
          hideSkeleton();
          render();
          renderFeaturedCards();
          showNotification('Önbellekten yüklendi', 'info');
        }

        try {
          const res = await fetch('data.json');
          const freshData = await res.json();
          
          setCache(freshData);
          
          if (JSON.stringify(freshData) !== JSON.stringify(DATA)) {
            DATA = freshData;
            hideSkeleton();
            render();
            renderFeaturedCards();
            showNotification('Yeni mangalar yüklendi!', 'success');
          }
        } catch (err) {
          console.error("Veri yüklenemedi:", err);
          if (!cached) {
            document.getElementById('skeletonGrid').innerHTML = `
              <div class="col-span-full text-center py-12">
                <p class="text-red-400 text-lg">Veri yüklenemedi!</p>
                <p class="text-zinc-500 text-sm mt-2">data.json dosyasını kontrol edin.</p>
              </div>
            `;
          }
